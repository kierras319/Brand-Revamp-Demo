<!-- PRODUCT SECTION START -->
<div class="featured__compare__product" id="section-{{ section.id }}" data-section="FeaturedCompareProduct">
  <div class="{% if section.settings.section_width == 'full_width' %}container-fluid {% elsif section.settings.section_width == 'box_width' %}container-fluid section-padding-1{% elsif section.settings.section_width == 'default' %}container default {% endif %}">
    <div class="row section_main__row">
      <div class="col-lg-5 col-md-12 col-sm-12 {% if settings.section__animation__enable %}scroll-zoom {% endif %}">
        {% if section.settings.section_title != '' or section.settings.section_sub_title != '' %}
          <div class="section-title {{ section.settings.title_align }} pb-40">
            {% if section.settings.section_title != '' %}
              <h2>{{ section.settings.section_title }}</h2>
            {% endif %}

            {% if section.settings.section_sub_title != '' %}
              <p>{{ section.settings.section_sub_title }}</p>
            {% endif %}
          </div>
        {% endif %}
      </div>
      <div class="col-lg-7 col-md-12 col-sm-12 {% if settings.section__animation__enable %}scroll-zoom {% endif %}">
        <div class="compare__main__wrap">
          <div class="row">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'single_compare_item' -%}
                  <div class="col-lg-{{ block.settings.item_column_handle}} col-md-6 col-sm-6 col-12">
                    <div class="single__compare__product__wrap ">
                      {%- assign product = all_products[block.settings.compare_item_handle] -%}
                      <div class="item__compare__img">
                        <img loading="lazy"  src="{{ product | img_url: 'grande' }}" alt="{{ product.alt }}">
                      </div>

                      <div class="item__compare__content">
                        <h4>
                          <a href="{{ product.url }}">{{ product.title }}</a>
                        </h4>

                        <div class="featured-product-price">
                          <span>{{ product.variants.first.price | money }}</span>
                          {%- if product.variants.first.compare_at_price > product.variants.first.price -%}
                            <del>{{ product.variants.first.compare_at_price | money }}</del>
                          {%- endif -%}
                        </div>

                        {% if block.settings.compare_feature_item_enable %}
                          <div class="item__compare__feature">
                            <ul>
                              {% if block.settings.compare_feature_item_1 != '' %}
                                <li>{{ block.settings.compare_feature_item_1 }}</li>
                              {% endif %}
                              {% if block.settings.compare_feature_item_2 != '' %}
                                <li>{{ block.settings.compare_feature_item_2 }}</li>
                              {% endif %}
                              {% if block.settings.compare_feature_item_3 != '' %}
                                <li>{{ block.settings.compare_feature_item_3 }}</li>
                              {% endif %}
                              {% if block.settings.compare_feature_item_4 != '' %}
                                <li>{{ block.settings.compare_feature_item_4 }}</li>
                              {% endif %}
                              {% if block.settings.compare_feature_item_5 != '' %}
                                <li>{{ block.settings.compare_feature_item_5 }}</li>
                              {% endif %}
                            </ul>
                          </div>
                        {% endif %}

                        {%- if block.settings.button_title != '' -%}
                          <div class="item__compare__button mt-30">
                            <a class="theme-default-button" href="{{ product.url }}">
                              {{- block.settings.button_title -}}
                            </a>
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- PRODUCT SECTION END -->

<style>

    @media (min-width: 1366px){
      .featured__compare__product .section-title {
        padding-right: 50px;
      }
    }
    .featured__compare__product .section-title {
        padding-bottom: 0;
    }
    .item__compare__feature li {
        padding: 15px 0;
        border-bottom: 1px solid {{section.settings.compare__border__color}};
        display: flex;
        justify-content: space-between;
    }
    .item__compare__img {
        max-width: 50%;
        margin-bottom: 20px;
    }
    .item__compare__img img {
        border-radius: 10px;
    }
    .compare__main__wrap {
        padding: 50px;
        background:{{section.settings.compare__bg__color}};
        border: 1px solid {{section.settings.compare__bg__color}};
        box-shadow: 0 0 20px 10px rgba(0,0,0,.03);
    }

    @media (max-width: 575px){
      .compare__main__wrap{
          padding: 20px;
      }
    }

    .featured__compare__product .section_main__row {
        align-items: center;
    }
    .featured__compare__product .section-title p {
        width: 80%;
    }
    .item__compare__button .theme-default-button {
        border-radius: 100px;
    }
    .single__compare__product__wrap {
      margin: 15px 0;
  }
</style>

