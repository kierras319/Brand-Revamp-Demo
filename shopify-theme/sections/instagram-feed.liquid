<div class="instagramarea" id="section-{{ section.id }}"  data-section="Instagram_Area">


        {%- capture data_slick_activation -%}
        data-slick='{
        
        "infinite": true,
        "slidesToShow": {{section.settings.carsoule_banner_col}},
        "slidesToScroll": 1,
        "rows":{{ section.settings.product_casoule_row }},
        {% if section.settings.tab_arsoule_arrow_enable %}
        "arrows": true,
        "prevArrow": "<span class=&#x27;product-dec-icon product-dec-prev&#x27;><i class=&#x27;sli sli-arrow-left&#x27;></i></span>",
        "nextArrow": "<span class=&#x27;product-dec-icon product-dec-next&#x27;><i class=&#x27;sli sli-arrow-right&#x27;></i></span>",
        {%else%}
        "arrows": false,
        {%endif%}
        
        "responsive": [{
        "breakpoint": 1200,
        "settings": {
        "slidesToShow": {{section.settings.carsoule_banner_col}},
        "slidesToScroll": 1
        }
        },
        {
        "breakpoint": 1199,
        "settings": {
        "slidesToShow": {{section.settings.carsoule_banner_col_lg}},
        "slidesToScroll": 1
        }
        },
        {
        "breakpoint": 991,
        "settings": {
        "slidesToShow": {{section.settings.carsoule_banner_col_md}},
        "slidesToScroll": 1
        }
        },
        {
        "breakpoint": 767,
        "settings": {
        "slidesToShow": {{section.settings.carsoule_banner_col_sm}},
        "slidesToScroll": 1
        }
        },
        {
        "breakpoint": 575,
        "settings": {
        "slidesToShow": 2,
        "slidesToScroll": 1
        }
        }
        ]
        
        
        }'
        {%- endcapture -%}

  
  <div class="{% if section.settings.section_width == 'full_width' %}container-fluid {% elsif section.settings.section_width == 'box_width' %}container-fluid section-padding-1{% elsif section.settings.section_width == 'default' %}container default {% endif %}">
    
      {% if section.settings.section_title != '' or section.settings.section_sub_title != '' %}
        <div class="section-title {{ section.settings.title_align }} pb-40 {% if settings.section__animation__enable %}scroll-zoom {% endif %}">
          {% if section.settings.section_title != '' %}
            <h2>{{ section.settings.section_title }}</h2>
          {% endif %}
  
          {% if section.settings.section_sub_title != '' %}
            <p>{{ section.settings.section_sub_title }}</p>
          {% endif %}
        </div>
      {% endif %}
            
 	<div class="{% if section.settings.tab_arsoule_active %} instagram-slider-active carsoule_arrow_style {% endif %}row custom__column__padding {% if settings.section__animation__enable %}scroll-zoom {% endif %}" {{ data_slick_activation }}>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'single__instagram' -%}

        {%- liquid
          assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
          assign fetch_priority = 'auto'
          if section.index == 1
            assign fetch_priority = 'high'
          endif
          assign image_class = 'lazyload-main-image animated responsive-image__image'
          assign lazy_load = 'lazy'
        -%}
          
          {%- assign bset = block.settings -%}
            <div class="{% if section.settings.tab_arsoule_active %}col-md-12 {% else %} col-lg-{{block.settings.product_column_handle}} col-md-{{block.settings.product_column_handle_md}} col-sm-{{block.settings.product_column_handle_sm}} col-12 {% endif %} custom_margin_col">
              <div class="instagramarea__img">
                    <a href="{{ block.settings.instam_url }}" class="lazyload-wraper-position" style="padding-top:{{ 1 | divided_by: block.settings.img__instagram.aspect_ratio | times: 100}}%;">
                        {%- if block.settings.img__instagram -%}
                          
                              {% assign image_height = block.settings.img__instagram.width | divided_by: block.settings.img__instagram.aspect_ratio %}
                              {{ block.settings.img__instagram | image_url: width: 3840 | image_tag: width: block.settings.img__instagram.width, height: image_height, 
                              widths: widths, fetchpriority: fetch_priority, class: image_class, loading: lazy_load, alt: image.alt}}
                          
                            {%- else -%}
                            <img loading="lazy"  class="animated" src="https://placehold.co/550x600" alt="{{ image.alt }}">
                        {%- endif -%}

                    
                      <div class="instagramarea__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-instagram">
                          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                      </div>
                  </a>
              </div>
            </div>
        
        {%- endcase -%}
      {%- endfor -%}
      
      </div>
  </div>
</div>


{%- render 'section-style' -%}
{%- render 'heading-style' -%}

<style>
    .instagramarea__img {
      position: relative;
      margin-bottom: 15px;
    }
    .instagramarea__img:hover .instagramarea__icon {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
    .instagramarea__img img {
      width: 100%;
      border-radius:10px;
    }
    .instagramarea__icon {
      align-items: center;
      background: {{ settings.body_bg_color }};
      border-radius: 50%;
      display: flex;
      height: 55px;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.32s cubic-bezier(0.4, 0, 0.21, 0.99), transform 0.32s cubic-bezier(0.4, 0, 0.21, 0.99);
      width: 55px;
      will-change: transform;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -20%);
    }
    .instagramarea__icon svg {
      height: 24px;
      width: 24px;
    }
  
  .custom__column__padding {
    margin: 0 -7px;
  }
  .custom_margin_col {
      padding: 0 7px;
  }
  
</style>

