{{ 'auto-parts-search-filter.css' | asset_url | stylesheet_tag }}

<div class="auto__parts--search-filter small_pb small_pt" id="section-{{ section.id }}">
  <div class="{% if section.settings.section_width == 'full_width' %}container-fluid {% elsif section.settings.section_width == 'box_width' %}container-fluid section-padding-1{% elsif section.settings.section_width == 'default' %}container default {% endif %}">
    <div class="row">

      {% if section.settings.section_title != '' or section.settings.section_sub_title != '' %}
          <div class="col-12 {% if settings.section__animation__enable %}scroll-zoom {% endif %}">
            <div class="section-title {{ section.settings.title_align }} pb-40">
              {% if section.settings.section_title != '' %}
                <h2>{{ section.settings.section_title }}</h2>
              {% endif %}
      
              {% if section.settings.section_sub_title != '' %}
                <p>{{ section.settings.section_sub_title }}</p>
              {% endif %}
            </div>
          </div>
      {% endif %}

      
      <div class="col-12 {% if settings.section__animation__enable %}scroll-zoom {% endif %}">
        <make-model-year-search class="auto__parts--filter d-flex justify-content-between align-items-center">
          <div class="select">
            <select class="select__make_data select__select">
              <option value="anything">Select Make</option>
            </select>
          </div>
          <div class="select">
            <select class="select__model_data select__select" disabled="disabled">
              <option value="Model">Model</option>
            </select>
          </div>
          <div class="select">
            <select class="select__year_data select__select" disabled="disabled">
              <option value="select">Year</option>
            </select>
          </div>
          <div class="select">
            <select class="select__engine_data select__select" disabled="disabled">
              <option value="Engine">Engine</option>
            </select>
          </div>
          <a
            href="#"
            class="button button--primary search__url btn btn-fill-out rounded-0 staggered-animation text-uppercase animated"
            >Search</a
          >
        </make-model-year-search>
      </div>
    </div>
  </div>
</div>

{%- render 'section-style' -%}

{%- render 'heading-style' -%}


