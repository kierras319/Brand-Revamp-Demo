{% if product.media.size > 1 %}
<div class="pro-nav pro-nav-media carsoule_arrow_style" id="ProductThumbs">
  {% for media in product.media %}
  {%- assign featured_media = current_variant.featured_media | default: product.featured_media -%} 
  <a data-thumbnail-id="{{ media.id }}" data-media-id="{{ media.id }}" href="javascript: void(0)" data-image="{{ media | img_url: '600x600' }}"
     class="{% case media.media_type %}{% when 'external_video' %}video-nav{% when 'video' %}video-nav{% when 'model' %}modal-nav{% endcase %}">
    <img loading="lazy"  data-sizes="auto" src="{{ media | img_url: 'x110', scale: 2 }}" alt="{{ media.alt | strip_html }}">
  </a>
  {% endfor %}
</div>
{% endif %}